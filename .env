BOT_TOKEN=8811026352:AAGfKNtXV3ZYnsbSb8dxTiCikysihFGvkzU
OWNER_ID=8725194109
WEBHOOK_SECRET=generate_a_random_32char_string_here

# ── Railway provides this automatically when you add PostgreSQL plugin ────
# Copy from Railway dashboard → PostgreSQL → Connect → DATABASE_URL
DATABASE_URL=postgresql://postgres:password@postgres.railway.internal:5432/railway

# ── Railway sets this automatically ──────────────────────────────────────
# RAILWAY_PUBLIC_DOMAIN is auto-set by Railway — don't set it manually
# PORT is auto-set by Railway — don't set it manually

# ── Optional tuning ───────────────────────────────────────────────────────
LOG_LEVEL=INFO
MAX_HISTORY_PER_USER=50
RATE_LIMIT_PER_MINUTE=10
RATE_LIMIT_PER_DAY=200
DEFAULT_WATERMARK=@myqrro_bot
